import random
print("Guess my number (1-10)! You get 3 tries.")
secret = random.randint(0,10)
tries = 0
while tries < 3:
    guess = int(input("Guess: "))
    tries = tries + 1
    
    if guess == secret:
        print("Yes! You win.")
        break
    elif guess < secret:
        print("Too low. Try higher.")
    else:
        print("Too high. Try lower.")

if tries == 3:
    print("Game over. Secret was", secret)
