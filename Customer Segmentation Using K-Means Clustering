import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns

df = pd.read_csv("Mall_Customers.csv")
print("First 5 rows:")
print(df.head())
print("\nDataset info:")
print(df.info())

df.columns = ["CustomerID", "Gender", "Age", "Annual_Income", "Spending_Score"]
print("\nAfter renaming columns:")
print(df.head())

print("\nMissing values:")
print(df.isnull().sum())

df[["Age", "Annual_Income", "Spending_Score"]].hist(bins=15, figsize=(12, 5), color="skyblue", edgecolor="black")
plt.suptitle("Distribution of Age, Income, and Spending Score")
plt.tight_layout()
plt.show()

X = df[["Annual_Income", "Spending_Score"]]
print("\nFeatures for clustering:")
print(X.head())

from sklearn.preprocessing import StandardScaler
scaler = StandardScaler()
X_scaled = scaler.fit_transform(X)
print("\nScaled features (first 5 rows):")
print(X_scaled[:5])

from sklearn.cluster import KMeans

wcss = []
for k in range(1, 11):
    kmeans = KMeans(n_clusters=k, init="k-means++", random_state=42)
    kmeans.fit(X_scaled)
    wcss.append(kmeans.inertia_)

plt.figure(figsize=(8, 5))
plt.plot(range(1, 11), wcss, marker="o", linestyle="-", color="purple")
plt.title("Elbow Method for Choosing Number of Clusters")
plt.xlabel("Number of clusters (k)")
plt.ylabel("WCSS (Within‑cluster sum of squares)")
plt.grid(True, alpha=0.3)
plt.show()

k = 5

kmeans = KMeans(n_clusters=k, init="k-means++", random_state=42)
clusters = kmeans.fit_predict(X_scaled)
df["Cluster"] = clusters

print("\nFirst 10 rows with cluster labels:")
print(df.head(10))

plt.figure(figsize=(10, 6))
colors = ["red", "blue", "green", "purple", "orange"]

for cluster_label in range(k):
    subset = df[df["Cluster"] == cluster_label]
    plt.scatter(
        subset["Annual_Income"],
        subset["Spending_Score"],
        c=colors[cluster_label],
        label=f"Cluster {cluster_label}",
        s=50,
        alpha=0.8
    )

plt.title("Customer Segments: Annual Income vs Spending Score")
plt.xlabel("Annual Income (k$)")
plt.ylabel("Spending Score (1–100)")
plt.legend()
plt.grid(True, alpha=0.3)
plt.show()

print("\nAverage income and spending score for each cluster:")
cluster_profiles = df.groupby("Cluster")[["Annual_Income", "Spending_Score"]].mean()
print(cluster_profiles)

print("\nNumber of customers in each cluster:")
print(df["Cluster"].value_counts().sort_index())

def predict_customer_segment(annual_income, spending_score):
    input_scaled = scaler.transform([[annual_income, spending_score]])
    cluster = kmeans.predict(input_scaled)[0]

    segments = {
        0: "Low‑income, low‑spending customers",
        1: "High‑income, high‑spending customers",
        2: "Moderate‑income, moderate‑spending customers",
        3: "High‑income, low‑spending customers",
        4: "Low‑income, high‑spending customers",
    }
    print(f"New customer: Income = {annual_income}k$, Spending Score = {spending_score}")
    print(f"Predicted segment: {segments.get(cluster, 'Unknown')}")

print("\nSegment predictions for new customers:")
predict_customer_segment(80, 90)
predict_customer_segment(20, 50)
predict_customer_segment(60, 20)
